# Neo4j connection (Docker service DNS — used inside docker-compose)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillmap_dev

# NextAuth — https://next-auth.js.org/configuration/options
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Comma-separated list of Google email addresses that receive the "admin" role.
# All other authenticated users receive the "user" role.
ADMIN_EMAILS=sacaleanu43@gmail.com
